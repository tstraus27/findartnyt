{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://art-exhibition-discovery.local/schemas/exhibition.schema.json",
  "title": "Canonical Exhibition",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "venue",
    "startDate",
    "sourceUrl",
    "reviewStatus",
    "sources",
    "createdAt",
    "updatedAt"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^exhibition:"
    },
    "type": {
      "const": "exhibition"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "venue": {
      "type": "string",
      "minLength": 1
    },
    "startDate": {
      "$ref": "#/$defs/dateLike"
    },
    "endDate": {
      "$ref": "#/$defs/nullableDateLike"
    },
    "description": {
      "type": [
        "string",
        "null"
      ]
    },
    "artists": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "curators": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "venueAddress": {
      "type": [
        "string",
        "null"
      ]
    },
    "neighborhood": {
      "type": [
        "string",
        "null"
      ]
    },
    "borough": {
      "type": [
        "string",
        "null"
      ]
    },
    "city": {
      "type": "string",
      "default": "New York"
    },
    "imageUrl": {
      "$ref": "#/$defs/nullableUri"
    },
    "exhibitionUrl": {
      "$ref": "#/$defs/nullableUri"
    },
    "sourceUrl": {
      "$ref": "#/$defs/uri"
    },
    "openingReceptionDate": {
      "$ref": "#/$defs/nullableDateLike"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "sourceConfidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "unknown"
      ]
    },
    "reviewStatus": {
      "type": "string",
      "enum": [
        "approved",
        "needs_review",
        "rejected",
        "archived"
      ]
    },
    "lastCheckedAt": {
      "$ref": "#/$defs/nullableDateTime"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sourceClaim"
      }
    },
    "changeHistory": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/changeEvent"
      }
    },
    "createdAt": {
      "$ref": "#/$defs/dateTime"
    },
    "updatedAt": {
      "$ref": "#/$defs/dateTime"
    }
  },
  "$defs": {
    "uri": {
      "type": "string",
      "format": "uri"
    },
    "nullableUri": {
      "anyOf": [
        {
          "$ref": "#/$defs/uri"
        },
        {
          "type": "null"
        }
      ]
    },
    "dateLike": {
      "type": "string",
      "pattern": "^\\d{4}(-\\d{2})?(-\\d{2})?$"
    },
    "nullableDateLike": {
      "anyOf": [
        {
          "$ref": "#/$defs/dateLike"
        },
        {
          "type": "null"
        }
      ]
    },
    "dateTime": {
      "type": "string",
      "format": "date-time"
    },
    "nullableDateTime": {
      "anyOf": [
        {
          "$ref": "#/$defs/dateTime"
        },
        {
          "type": "null"
        }
      ]
    },
    "sourceClaim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "url",
        "sourceType",
        "reliability",
        "claimFields",
        "checkedAt"
      ],
      "properties": {
        "url": {
          "$ref": "#/$defs/uri"
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "official_venue",
            "gallery",
            "museum",
            "press",
            "newsletter",
            "aggregator",
            "other"
          ]
        },
        "reliability": {
          "type": "string",
          "enum": [
            "high",
            "medium",
            "low",
            "unknown"
          ]
        },
        "claimFields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "checkedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "changeEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "changedAt",
        "changeType",
        "actor",
        "summary"
      ],
      "properties": {
        "changedAt": {
          "$ref": "#/$defs/dateTime"
        },
        "changeType": {
          "type": "string",
          "enum": [
            "created",
            "approved_update",
            "manual_edit",
            "source_refresh",
            "archived"
          ]
        },
        "actor": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "sourceUrl": {
          "$ref": "#/$defs/nullableUri"
        }
      }
    }
  }
}
